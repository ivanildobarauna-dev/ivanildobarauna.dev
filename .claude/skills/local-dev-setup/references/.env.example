# PostgreSQL SSH Tunnel Configuration
# This IP will be used by the skill to establish the SSH tunnel
POSTGRES_HOST=0.0.0.0

# PostgreSQL Connection Details (used by your application)
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=portfolio_db

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend Configuration
BACKEND_PORT=8090
FLASK_ENV=development
FLASK_DEBUG=1

# Frontend Configuration
NEXT_PUBLIC_BACKEND_URL=http://localhost:8090/api/v1
NODE_ENV=development

# Optional: Datadog Monitoring
# DD_ENABLED=false
# DD_SERVICE=portfolio-dev
# DD_ENV=development
